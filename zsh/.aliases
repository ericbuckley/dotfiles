# vim: ft=zsh
alias sudo='sudo '
alias c='clear'

alias vim='nvim'
alias lg='lazygit'

alias urlencode='python3 -c "import sys, urllib.parse as ul; print (ul.quote_plus(sys.argv[1]))"'
alias urldecode='python3 -c "import sys, urllib.parse as ul; print(ul.unquote_plus(sys.argv[1]))"'

alias dco='docker compose'
alias dcb='docker compose build'
alias dcrr='docker compose run --rm --service-ports'
alias docker-clean='docker system prune -a --volumes -f'

# PI CLI shortcuts
pi-commit() {
  local template="${PI_CODING_AGENT_DIR}/prompts/commit.md"
  local commit_message

  commit_message=$(pi --model google/gemini-flash-lite-latest --no-session -nc -ne -ns -np -p "$(cat "$template")" 2>/dev/null)

  if [[ -z "${commit_message//[[:space:]]/}" ]]; then
    echo "Generated commit message was empty" >&2
    return 1
  fi

  local tmp
  tmp=$(mktemp)
  trap 'rm -f "$tmp"' EXIT
  printf '%s\n' "$commit_message" > "$tmp"
  git commit -e -F "$tmp"
}

pi-pr-desc() {
  local base="${1:-main}"
  local template="${PI_CODING_AGENT_DIR}/prompts/pr-description.md"
  local prompt

  prompt=$(sed "s/\$1/${base}/g" "$template")
  pi --model google/gemini-flash-lite-latest --no-session -nc -ne -ns -np -p "$prompt" 2>/dev/null
}

pi-jira-desc() {
  local desc="${1}"
  local template="${PI_CODING_AGENT_DIR}/prompts/jira-description.md"
  local prompt

  prompt=$(sed "s/\$1/${desc}/g" "$template")
  pi --model google/gemini-flash-latest --no-session -nc -ne -ns -np -p "$prompt" 2>/dev/null
}
